#!/usr/bin/env bash
# Enforce Conventional Commits (see CLAUDE.md § Commits).
#
# Zero-dependency on purpose: this is a Python repo, and pulling in Node +
# husky + commitlint to lint one line of text would be a whole toolchain for
# no gain.
#
# Enable once per clone:
#     git config core.hooksPath .githooks
#
# `core.hooksPath` is local config, not a tracked file — git will not run hooks
# from a fresh clone without it, by design (a repo that could silently execute
# code on checkout would be a supply-chain hole).

set -euo pipefail

subject=$(head -n 1 "$1")

# Git generates these itself; they are not ours to shape.
case "$subject" in
	Merge\ *|Revert\ *|fixup!\ *|squash!\ *|amend!\ *) exit 0 ;;
esac

types='feat|fix|docs|refactor|test|perf|build|ci|chore|revert'
pattern="^(${types})(\([a-z0-9._/-]+\))?!?: .+"

if ! printf '%s' "$subject" | grep -Eq "$pattern"; then
	cat >&2 <<-EOF

		✗ Commit message is not a Conventional Commit.

		  got:      ${subject}
		  expected: <type>(<optional scope>): <description>

		  type is one of: feat, fix, docs, refactor, test, perf, build, ci, chore, revert
		  append ! for a breaking change, e.g.  feat(store)!: drop the legacy schema

		  e.g.  fix(canonical): verify the embedding-model lock before searching

		See CLAUDE.md § Commits. To bypass deliberately: git commit --no-verify

	EOF
	exit 1
fi

if [ "${#subject}" -gt 72 ]; then
	printf '\n✗ Subject line is %d chars; keep it under 72.\n\n  %s\n\n' \
		"${#subject}" "$subject" >&2
	exit 1
fi
